# Dependencias de Node
node_modules/

# Variables de entorno y credenciales
.env

# Carpetas locales de la aplicación
/Inbox/
/CDU/
/Cuarentena/
/Reintentos/
/Recycling/
/Fichero/
/logs/
/Source Repo/
/Test Battery/
/DUMPS/

# Archivos temporales de procesamiento (Importante)
/temp/

# Carpetas de log o basura del sistema
*.log
.DS_Store
Thumbs.db

# editor/backup leftovers
*.bak

# mockups de diseño (no son assets de producción)
LoginPageMockup.jpg

# Manifiestos de scripts de recuperación (llevan ids de documentos; no van a git)
manifiesto-*.json

# Sello de versión: lo GENERA el script de despliegue en el NAS (sha + rama + nº de serie). Derivado, no
# va a git; el rsync ya lo excluye para no pisar el del NAS.
/VERSION
