{
  "name": "Bibliotheca Ludoviciana",
  "short_name": "Biblioteca",
  "description": "Catálogo y alta de recursos de la biblioteca",
  "lang": "es",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0e1116",
  "theme_color": "#0e1116",
  "icons": [
    { "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any maskable" },
    { "src": "/logo.png", "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/LogoBig.png", "sizes": "512x512", "type": "image/png", "purpose": "any" }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "files", "accept": ["application/pdf", "image/*"] }
      ]
    }
  }
}
