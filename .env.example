# ---------------------------------------------------------------------------
# .env — SECRETOS y rutas (este fichero NO va a git: cópialo a `.env` y ajústalo).
#
# Los AJUSTES numéricos (timeouts, intervalos, tamaños de portada/PDF/OCR, cadencia
# del mantenimiento...) NO viven aquí: están en `src/config.js` (va en git, se edita
# en el repo y en la app desplegada). Solo añade aquí una de esas claves si quieres
# un override que SOBREVIVA a los despliegues en una máquina concreta (env > config).
# ---------------------------------------------------------------------------

# --- Conexión y claves (OBLIGATORIO) ---------------------------------------
MONGO_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/?retryWrites=true
MONGO_DB_NAME=Biblioteca
GEMINI_API_KEY=tu_clave_gemini
GOOGLE_BOOKS_API_KEY=tu_clave_google_books

# --- Rutas (en Docker las fija docker-compose; en local, relativas a la raíz) ---
PATH_INBOX=Inbox
PATH_CDU=CDU
PATH_CUARENTENA=Cuarentena
PATH_REINTENTOS=Reintentos
PATH_ER_ROOM=_ER Room         # archivos vacíos (0 bytes) del Inbox: preserva el nombre para redescargar
                              # En Docker se inyecta vía compose environment (PATH_ER_ROOM=/app/_ER Room)
PATH_RECICLAJE=Recycling      # papelera: política "nunca borrar" — los ficheros retirados del Inbox se
                              # MUEVEN aquí (subcarpeta serializada) en vez de borrarse. Vaciar a mano.

# --- Interruptores (presencia/valor; por eso no van en config.js) ----------
# DESACTIVAR_VIGILANTE=1     # solo API, sin watcher del Inbox
# VIGILANTE_POLLING=0        # desactiva el sondeo (solo donde inotify es fiable; NO en el NAS)
# MANTENIMIENTO_ACTIVO=0     # desactiva el proceso de mantenimiento durmiente
TZ=Europe/Madrid              # zona horaria del contenedor (afecta a la marca de tiempo de los logs)
