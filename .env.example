# ---------------------------------------------------------------------------
# .env — SECRETOS y rutas (este fichero NO va a git: cópialo a `.env` y ajústalo).
#
# Los AJUSTES numéricos (timeouts, intervalos, tamaños de portada/PDF/OCR, cadencia
# del mantenimiento...) NO viven aquí: están en `src/config.js` (va en git, se edita
# en el repo y en la app desplegada). Solo añade aquí una de esas claves si quieres
# un override que SOBREVIVA a los despliegues en una máquina concreta (env > config).
# ---------------------------------------------------------------------------

# --- Conexión y claves (OBLIGATORIO) ---------------------------------------
MONGO_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/?retryWrites=true
MONGO_DB_NAME=Biblioteca
GEMINI_API_KEY=tu_clave_gemini
GOOGLE_BOOKS_API_KEY=tu_clave_google_books

# --- Rutas (en Docker las fija docker-compose; en local, relativas a la raíz) ---
PATH_INBOX=Inbox
PATH_CDU=CDU
PATH_CUARENTENA=Cuarentena
PATH_REINTENTOS=Reintentos
PATH_RECICLAJE=Recycling      # papelera: política "nunca borrar" — los ficheros retirados del Inbox se
                              # MUEVEN aquí (subcarpeta serializada) en vez de borrarse. Vaciar a mano.
PATH_FICHERO=Fichero          # carpeta con fichero.db (volcados OL+BNE offline, Tier-2 principal). Puede
                              # ser un directorio (usa <dir>/fichero.db) o la ruta directa a un .db.
                              # Si falta, el proveedor local se desactiva y se usan solo las APIs online.

# --- Puertos ---------------------------------------------------------------
# PORT=3000                  # API REST de ingesta (por defecto 3000)
# PANEL_PORT=4000            # Panel de control web (por defecto 4000; 0 lo desactiva)

# --- Panel de control: autenticación ---------------------------------------
ADMIN_PWD=cambia_esto         # contraseña del admin (usuario "Luis"): acceso TOTAL al panel
GUEST_PWD=guest               # contraseña del invitado (usuario "guest"): SOLO LECTURA (stats/búsqueda)
# Usuarios ADICIONALES (pocos; admin o guest) como JSON; sobrescriben por nombre a Luis/guest. No hay
# alta/recuperación por UI: se editan aquí. El login los muestra en un desplegable. Ejemplo:
# PANEL_USERS=[{"user":"María","rol":"admin","pwd":"cambia"},{"user":"invitado","rol":"guest","pwd":"cambia"}]
# Auto-login por URL: abrir https://usuario:contraseña@host:puerto entra directo (cabecera Basic → token).

# --- Interruptores (presencia/valor; por eso no van en config.js) ----------
# DESACTIVAR_VIGILANTE=1     # solo API, sin watcher del Inbox
# VIGILANTE_AUTOSTART=1      # arranca el vigilante ACTIVO (por defecto arranca PAUSADO; se activa en el panel)
# VIGILANTE_POLLING=0        # desactiva el sondeo (solo donde inotify es fiable; NO en el NAS)
# MANTENIMIENTO_ACTIVO=1     # OPT-IN al mantenimiento AUTO al reposo (por defecto es manual)
TZ=Europe/Madrid              # zona horaria del contenedor (afecta a la marca de tiempo de los logs)

# --- "Buscar copia" al sanear ilegibles (sobrescribe config.js; sobrevive a despliegues) -----
# Estos dominios ROTAN. Cuando Anna's Archive / Z-Library cambien de TLD, edita el dominio aquí
# (una sola línea JSON; {q} = la consulta). Es un override de FUENTES_COPIA de config.js:
# FUENTES_COPIA=[{"nombre":"Anna's Archive","url":"https://annas-archive.se/search?q={q}"},{"nombre":"Z-Library","url":"https://z-library.sk/s/?q={q}"},{"nombre":"Libgen","url":"https://libgen.bz/index.php?req={q}"},{"nombre":"Gutenberg","url":"https://www.gutenberg.org/ebooks/search/?query={q}"}]
