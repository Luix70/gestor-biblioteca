# ---------------------------------------------------------------------------
# Plantilla de configuración. Copia a `.env` y ajusta. El contenedor lee este
# fichero al arrancar (bind mount → /app/.env + dotenv), así que basta con
# añadir una línea y reiniciar el contenedor — sin recompilar.
#
# Todo valor tiene un DEFAULT en el código: solo hace falta poner aquí lo que
# quieras cambiar. Las claves marcadas (*) las inyecta también docker-compose
# (environment:), que tiene prioridad sobre dotenv para ESAS.
# ---------------------------------------------------------------------------

# --- Secretos y conexión (OBLIGATORIOS) (*) --------------------------------
MONGO_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/?retryWrites=true
MONGO_DB_NAME=Biblioteca
GEMINI_API_KEY=tu_clave_gemini
GOOGLE_BOOKS_API_KEY=tu_clave_google_books

# --- Rutas (en Docker las fija docker-compose; en local relativas a la raíz) (*)
PATH_INBOX=Inbox
PATH_CDU=CDU
PATH_CUARENTENA=Cuarentena
PATH_REINTENTOS=Reintentos

# --- General ---------------------------------------------------------------
PORT=3000                      # puerto de la API REST
HTTP_TIMEOUT_MS=20000          # timeout de TODA llamada HTTP a las APIs bibliográficas
DESACTIVAR_VIGILANTE=          # =1 → solo API, sin watcher del Inbox
# TZ=Europe/Madrid             # zona horaria del contenedor (afecta a la marca de tiempo de los logs)

# --- Vigilante del Inbox ---------------------------------------------------
PAUSA_INGESTA_MS=1500          # pausa entre recursos (no saturar APIs)
REPOSO_INBOX_MS=2500           # espera tras el último cambio antes de procesar (ruta por eventos)
VIGILANTE_POLLING=             # =0 → desactiva el sondeo (solo donde inotify es fiable; NO en el NAS)
VIGILANTE_POLL_MS=1500         # intervalo de sondeo de chokidar
VIGILANTE_ESCANEO_MS=10000     # cada cuánto se reescanea el Inbox (red de seguridad del NAS)
VIGILANTE_ESTABILIDAD_MS=1500  # ventana para confirmar que un archivo terminó de escribirse

# --- Mantenimiento (Conformador) -------------------------------------------
MANTENIMIENTO_ACTIVO=          # =0 → desactiva el proceso de mantenimiento durmiente
MANTENIMIENTO_REPOSO_MS=300000 # Inbox inactivo necesario antes de una pasada (5 min)
MANTENIMIENTO_LOTE=25          # documentos por pasada (disparo automático)
MANTENIMIENTO_PAUSA_MS=800     # pausa entre documentos durante el mantenimiento

# --- Portadas (resolver-portada) -------------------------------------------
PORTADA_ANCHO_OBJETIVO=1000    # ancho ideal; por debajo se intenta mejorar (rasterizar, etc.)
PORTADA_ANCHO_DECENTE=500      # si ya hay algo así de ancho, no se descargan portadas remotas
PORTADA_ANCHO_MINIMO=100       # por debajo = imagen degenerada y se descarta (p. ej. el 1x1 de OL)

# --- PDF: extracción de texto, rasterizado y OCR ---------------------------
PDF_PAGINAS_FRENTE=15          # nº de primeras páginas de las que se extrae texto (ISBN/título)
PDF_PAGINAS_FONDO=5            # nº de últimas páginas de las que se extrae texto
PDF_RASTER_ANCHO=1024          # ancho del rasterizado de portada (poppler)
PDF_OCR_PAGINAS=5              # nº de primeras páginas (+ la última) que se OCR-ean si está escaneado
PDF_OCR_ANCHO=1600             # ancho del rasterizado para OCR (más alto = ISBN legible)
